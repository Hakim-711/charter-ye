PORT=10000
NODE_ENV=production
DATABASE_URL="file:/opt/render/project/src/backend/data/prod.db"
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=8h
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=10
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=replace_with_strong_admin_password
ALLOWED_ORIGINS=https://charter-ye.netlify.app,https://charter-ye.com,https://www.charter-ye.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
LEAD_NOTIFICATION_TO=info@charter-ye.com
LEAD_NOTIFICATION_FROM=
BACKUP_ENABLED=true
BACKUP_DIRECTORY=/opt/render/project/src/backend/data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_COUNT=14
